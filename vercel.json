{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/socket.io/(.*)",
      "destination": "https://multibroker-fariq-efriadi-production.up.railway.app"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
